# Copy to terraform.tfvars and fill in values
# DO NOT commit terraform.tfvars — it contains secrets

# ── Hetzner Cloud ──────────────────────────────────────────────
hcloud_token   = ""
ssh_public_key = "ssh-ed25519 AAAA..."

# ── S3 State Backend (Hetzner Object Storage) ─────────────────
# Create a bucket and S3 credentials in your Hetzner project
hetzner_s3_access_key = ""
hetzner_s3_secret_key = ""
s3_bucket             = "my-club-tfstate"
s3_endpoint           = "https://nbg1.your-objectstorage.com"

# ── DNS (managed via hcloud API — same token as above) ────────
domain = "klubb.no"

# ── Email (Resend) — leave empty to skip DNS records ─────────
# Get these values from https://resend.com/domains after adding your domain
# resend_dkim_value = "p=MIGfMA0GCS..."
# resend_spf_value  = "v=spf1 include:amazonses.com ~all"
# resend_mx_value   = "feedback-smtp.us-east-1.amazonses.com"

# ── Optional overrides (defaults shown) ────────────────────────
# server_name = "brygge"
# server_type = "cax11"       # ARM64: cax11 (2vCPU/4GB), cax21 (4vCPU/8GB)
# location    = "fsn1"        # fsn1=Falkenstein, nbg1=Nuremberg, hel1=Helsinki
# image       = "debian-12"
