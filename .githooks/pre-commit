#!/usr/bin/env bash
# Pre-commit hook: block commits of terraform/terraform.tfvars.json unless
# the staged version contains only placeholder values (no real secrets).
# Each deployer fills in secrets in their working copy. To prevent those
# from ever being staged, run once per clone:
#
#   git update-index --skip-worktree terraform/terraform.tfvars.json
#
# This hook is a second line of defence in case skip-worktree is cleared
# or someone uses `git add -f`.

set -e

staged_tfvars=$(git diff --cached --name-only | grep -x 'terraform/terraform.tfvars.json' || true)

if [ -n "$staged_tfvars" ]; then
  # Allow placeholder-only commits (e.g. adding new fields with empty/default
  # values). A placeholder file has no hcloud_token and uses example.invalid.
  staged_content=$(git show :terraform/terraform.tfvars.json)
  has_token=$(echo "$staged_content"    | python3 -c "import sys,json; d=json.load(sys.stdin); print('yes' if d.get('hcloud_token','') != '' else 'no')" 2>/dev/null || echo "err")
  has_real_domain=$(echo "$staged_content" | python3 -c "import sys,json; d=json.load(sys.stdin); print('yes' if not d.get('domain','example.invalid').endswith('example.invalid') else 'no')" 2>/dev/null || echo "err")

  if [ "$has_token" = "yes" ] || [ "$has_real_domain" = "yes" ] || [ "$has_token" = "err" ] || [ "$has_real_domain" = "err" ]; then
    cat >&2 <<'EOF'
═══════════════════════════════════════════════════════════════════════
 refusing to commit terraform/terraform.tfvars.json

 That file is tracked with placeholder values only. Your working copy
 contains secrets that must never be committed.

 To keep your local edits invisible to git:
   git reset HEAD terraform/terraform.tfvars.json
   git update-index --skip-worktree terraform/terraform.tfvars.json

 To update the committed placeholder (rare, requires skip-worktree off):
   git update-index --no-skip-worktree terraform/terraform.tfvars.json
   git add -f terraform/terraform.tfvars.json
   # commit only a sanitized/placeholder version
═══════════════════════════════════════════════════════════════════════
EOF
    exit 1
  fi
fi
