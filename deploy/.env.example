# Brygge — Environment Configuration
# Copy to .env and fill in values

# ── Domain & Club ────────────────────────────────────────────
DOMAIN=example.com
CLUB_SLUG=moss-batklubb
CLUB_NAME="Moss Båtklubb"

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=brygge
POSTGRES_USER=brygge
POSTGRES_PASSWORD=CHANGE_ME
DATABASE_URL=postgres://brygge:CHANGE_ME@db:5432/brygge?sslmode=disable

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Frontend ─────────────────────────────────────────────────
# Used in magic link emails and redirects
FRONTEND_URL=https://example.com

# ── JWT Auth ─────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_A_RANDOM_STRING
# JWT_ACCESS_EXPIRY=15m
# JWT_REFRESH_EXPIRY=168h

# ── TOTP (admin step-up auth) ────────────────────────────────
# Generate with: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# ── Vipps MobilePay ──────────────────────────────────────────
VIPPS_CLIENT_ID=
VIPPS_CLIENT_SECRET=
VIPPS_CALLBACK_URL=https://example.com/api/v1/auth/vipps/callback
VIPPS_TEST_MODE=true

# Vipps ePayment (for orders and payments)
VIPPS_MSN=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_WEBHOOK_SECRET=

# ── Transactional Email (Resend) ─────────────────────────────
# See docs/resend.md for setup
RESEND_API_KEY=
RESEND_FROM_ADDRESS=noreply@example.com

# ── S3-compatible Object Storage (Hetzner) ───────────────────
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=brygge-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Dendrite (Matrix homeserver) ─────────────────────────────
DENDRITE_SERVER_NAME=matrix.example.com
# DENDRITE_INTERNAL_URL=http://dendrite:8008
DENDRITE_SERVICE_TOKEN=

# ── Web Push (VAPID) ────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── TLS (Let's Encrypt) ─────────────────────────────────────
LETSENCRYPT_EMAIL=admin@example.com

# ── OpenTelemetry (optional) ─────────────────────────────────
# See docs/otel.md for collector setup
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production

# ── AI (optional — Anthropic API for document summaries) ─────
# ANTHROPIC_API_KEY=

# ── Feature Flags (all default true except accounting) ───────
# FEATURE_BOOKINGS=true
# FEATURE_PROJECTS=true
# FEATURE_CALENDAR=true
# FEATURE_COMMERCE=true
# FEATURE_COMMUNICATIONS=true
# FEATURE_ACCOUNTING=false

# ── Database Pool (optional tuning) ─────────────────────────
# DB_MAX_CONNS=20
# DB_MIN_CONNS=2
# DB_MAX_CONN_LIFETIME=30m
# DB_MAX_CONN_IDLE_TIME=5m
# DB_STATEMENT_TIMEOUT=30000
