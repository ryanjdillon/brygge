# Brygge — Environment Configuration
#
# For docker-compose deploys: copy this to `deploy/.env` and fill in.
# For NixOS deploys: this file lives at `/etc/brygge/env` (root-owned, 0400)
#   and only needs to carry the secrets — everything tagged [nix-injected]
#   is set by the systemd unit from clubConfig (terraform/terraform.tfvars.json).
#
# Tags:
#   [nix-injected]  → auto-set on NixOS deploys; only needed for docker-compose
#   [compose-only]  → only consumed by the docker-compose containers (postgres,
#                     traefik, dendrite); brygge itself doesn't read these
#
# Full env-var layering rule (clubConfig vs nix-injected vs env file):
# see ../AGENTS.md#env-var-layering

# ── Domain & Club ────────────────────────────────────────────
DOMAIN=example.com                  # [nix-injected] from clubConfig.domain
FRONTEND_URL=https://example.com    # [nix-injected] from clubConfig.domain
CLUB_SLUG=moss-batklubb             # [nix-injected] from clubConfig.slug
CLUB_NAME="Moss Båtklubb"           # [nix-injected] from clubConfig.name

# ── PostgreSQL ───────────────────────────────────────────────
# Generate password: openssl rand -base64 32
# Then paste the same value in both POSTGRES_PASSWORD and DATABASE_URL.
# POSTGRES_* are read by the docker-compose postgres container itself,
# not by brygge. On NixOS deploys the postgres service is configured by
# nix and brygge talks to it via the local Unix socket.
POSTGRES_DB=brygge                                                              # [compose-only]
POSTGRES_USER=brygge                                                            # [compose-only]
POSTGRES_PASSWORD=CHANGE_ME                                                     # [compose-only]
DATABASE_URL=postgres://brygge:CHANGE_ME@db:5432/brygge?sslmode=disable         # [nix-injected]

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0      # [nix-injected] uses unix socket on NixOS

# ── TOTP (admin step-up auth — required for /admin/* access) ─
# Generate with: openssl rand -hex 32
# WARNING: rotating this key after enrollments exist makes every
# enrolled user unrecoverable. See docs/security/2fa.md.
TOTP_ENCRYPTION_KEY=

# ── Vipps ePayment (for orders and payments) ─────────────────
# Vipps Login was removed in DIL-28; only the ePayment integration
# remains. VIPPS_TEST_MODE=true points VippsBaseURL() at apitest.vipps.no.
VIPPS_TEST_MODE=true
VIPPS_MSN=
VIPPS_SUBSCRIPTION_KEY=
VIPPS_WEBHOOK_SECRET=

# ── Transactional Email (SMTP) ───────────────────────────────
# See docs/mail/setup.md for the self-hosted Stalwart setup. Brygge
# authenticates as a dedicated relay@ principal on port 465.
# In docker-compose dev, these are overridden to point at MailPit
# (mock SMTP) — see deploy/docker-compose.dev.yml.
SMTP_HOST=mail.example.com
SMTP_PORT=465
SMTP_USERNAME=relay
SMTP_PASSWORD=
EMAIL_FROM="Example Club <relay@example.com>"
EMAIL_REPLY_TO=info@example.com

# ── S3-compatible Object Storage (Hetzner) ───────────────────
S3_ENDPOINT=https://fsn1.your-objectstorage.com
S3_BUCKET=brygge-documents
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ── Dendrite (Matrix homeserver) ─────────────────────────────
DENDRITE_SERVER_NAME=matrix.example.com   # [compose-only] read by the dendrite container
# DENDRITE_INTERNAL_URL=http://dendrite:8008   # consumed by brygge; default is fine for compose
DENDRITE_SERVICE_TOKEN=

# ── Web Push (VAPID) ────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── TLS (Let's Encrypt) ─────────────────────────────────────
LETSENCRYPT_EMAIL=admin@example.com   # [compose-only] read by traefik; NixOS uses security.acme

# ── OpenTelemetry (optional) ─────────────────────────────────
# [nix-injected] OTEL_EXPORTER_OTLP_ENDPOINT/PROTOCOL/SERVICE_NAME and
# OTEL_TRACES_SAMPLER_ARG come from services.brygge.extraEnvironment
# in nix/host.nix. See docs/otel/index.md for collector setup.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production
# OTEL_TRACES_SAMPLER_ARG=0.1   # 10% trace sampling; bump to 1.0 during incident debugging

# ── AI (optional — Anthropic API for document summaries) ─────
# ANTHROPIC_API_KEY=

# ── Feature Flags ────────────────────────────────────────────
# [nix-injected] from clubConfig.features (DIL-219). Defaults: all true
# except FEATURE_ACCOUNTING and FEATURE_DEMO_AUTH (both false).
# Override in tfvars.features, or set here for docker-compose deploys.
# FEATURE_BOOKINGS=true
# FEATURE_PROJECTS=true
# FEATURE_CALENDAR=true
# FEATURE_COMMERCE=true
# FEATURE_COMMUNICATIONS=true
# FEATURE_ACCOUNTING=false
# FEATURE_DEMO_AUTH=false

# ── Database Pool (optional tuning) ─────────────────────────
# DB_MAX_CONNS=20
# DB_MIN_CONNS=2
# DB_MAX_CONN_LIFETIME=30m
# DB_MAX_CONN_IDLE_TIME=5m
# DB_STATEMENT_TIMEOUT=30000
